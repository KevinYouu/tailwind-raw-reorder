{
    "name": "tailwind-raw-reorder-next",
    "displayName": "Tailwind Raw Reorder Next",
    "description": "A high-performance Tailwind CSS class organizer for VS Code, redesigned with TypeScript and fully supporting Tailwind CSS v4's engine-less configuration.",
    "keywords": [
        "tailwind",
        "tailwindcss",
        "css",
        "sort",
        "sorter",
        "vscode",
        "v4"
    ],
    "galleryBanner": {
        "color": "#f1f5f8"
    },
    "icon": "tailwind-raw-reorder-next-icon.png",
    "version": "3.7.0",
    "publisher": "KevinYouu",
    "license": "MIT",
    "author": "KevinYouu <zdy295@gamil.com>",
    "repository": "https://github.com/KevinYouu/tailwind-raw-reorder-next",
    "engines": {
        "vscode": "^1.32.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onLanguage:html",
        "onLanguage:javascript",
        "onLanguage:javascriptreact",
        "onLanguage:typescript",
        "onLanguage:typescriptreact",
        "onLanguage:vue",
        "onLanguage:svelte",
        "onLanguage:css",
        "onLanguage:scss",
        "onLanguage:less",
        "onLanguage:postcss",
        "onLanguage:blade",
        "onLanguage:erb",
        "onLanguage:ejs",
        "onLanguage:haml",
        "onLanguage:pug",
        "onLanguage:twig",
        "onLanguage:xml"
    ],
    "main": "./dist/index.js",
    "contributes": {
        "commands": [
            {
                "command": "tailwind-raw-reorder-next.sortTailwindClasses",
                "title": "Tailwind Raw Reorder Next: Sort Tailwind CSS Classes"
            },
            {
                "command": "tailwind-raw-reorder-next.sortTailwindClassesOnWorkspace",
                "title": "Tailwind Raw Reorder Next: Sort Tailwind CSS Classes on Entire Workspace"
            },
            {
                "command": "tailwind-raw-reorder-next.sortTailwindClassesOnSelection",
                "title": "Tailwind Raw Reorder Next: Sort Tailwind CSS Classes on current Selection"
            }
        ],
        "keybindings": [
            {
                "command": "tailwind-raw-reorder-next.sortTailwindClasses",
                "key": "ctrl+alt+t",
                "mac": "shift+alt+t",
                "when": "editorFocus"
            }
        ],
        "configuration": [
            {
                "title": "Tailwind Raw Reorder Next",
                "properties": {
                    "tailwind-raw-reorder-next.classRegex": {
                        "type": "object",
                        "default": {
                            "jade": [
                                {
                                    "regex": "\\.([\\._a-zA-Z0-9\\-]+)",
                                    "separator": "\\.",
                                    "replacement": "."
                                },
                                "\\bclass\\s*=\\s*[\\\"\\']([\\._a-zA-Z0-9\\s\\-\\:\\/]+)[\\\"\\']"
                            ],
                            "html": [
                                "\\sclass=(([\"'`])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>])\\2",
                                "[\"'`]([^]+)"
                            ],
                            "css": "\\B@apply\\s+([\\._a-zA-Z0-9\\s\\-\\:\\/]+);",
                            "javascript": [
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*(([\"'`])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>]\\2)",
                                    "[\"'`]([^\"'`]+)[\"'`]"
                                ]
                            ],
                            "javascriptreact": [
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{\\s*cn\\s*\\(((?:[^()]|\\([^)]*\\))*)\\)",
                                    "[\"'`]([^\"'`]+)[\"'`]"
                                ],
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{\\s*(`[\\s\\S]*?`(?=\\s*\\}))",
                                    "`([\\s\\S]*)`"
                                ],
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{?(([\"'])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>]\\2)",
                                    "[\"']([^\"']+)[\"']"
                                ]
                            ],
                            "typescript": [
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{\\s*cn\\s*\\(((?:[^()]|\\([^)]*\\))*)\\)",
                                    "[\"'`]([^\"'`]+)[\"'`]"
                                ],
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{\\s*(`[\\s\\S]*?`(?=\\s*\\}))",
                                    "`([\\s\\S]*)`"
                                ],
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{?(([\"'])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>]\\2)",
                                    "[\"']([^\"']+)[\"']"
                                ]
                            ],
                            "typescriptreact": [
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{\\s*cn\\s*\\(((?:[^()]|\\([^)]*\\))*)\\)",
                                    "[\"'`]([^\"'`]+)[\"'`]"
                                ],
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{\\s*(`[\\s\\S]*?`(?=\\s*\\}))",
                                    "`([\\s\\S]*)`"
                                ],
                                [
                                    "(?:class(?:Name)?|tw)\\s*=\\s*\\{?(([\"'])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>]\\2)",
                                    "[\"']([^\"']+)[\"']"
                                ]
                            ],
                            "php": [
                                "\\sclass=(([\"'`])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>])\\2",
                                "[\"'`]([^]+)"
                            ],
                            "xml": [
                                [
                                    "class=(([\"'`])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>])\\2",
                                    "[\"'`]([^]+)"
                                ],
                                [
                                    "classes=(([\"'`])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>])\\2",
                                    "[\"'`]([^]+)"
                                ],
                                [
                                    "icon=(([\"'`])(?:(?:[^{}<>](?!\\2))|\\\\\\2)+[^{}<>])\\2",
                                    "[\"'`]([^]+)"
                                ]
                            ]
                        },
                        "description": "An object with language IDs as keys and their values determining the regex to search for Tailwind CSS classes.",
                        "scope": "window"
                    },
                    "tailwind-raw-reorder-next.runOnSave": {
                        "type": "boolean",
                        "default": true,
                        "description": "A flag that controls whether or not Tailwind Raw Reorder Next will sort your Tailwind CSS classes on save.",
                        "scope": "window"
                    }
                }
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "_pre": "rimraf dist && cpy node_modules/tailwindcss/lib/css dist/css",
        "_esbuild": "node build.mjs",
        "prebuild": "npm run _pre",
        "build": "npm run _esbuild -- --minify",
        "test": "vitest run",
        "test:watch": "vitest",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "1.32.0",
        "cpy-cli": "^5.0.0",
        "esbuild": "^0.19.4",
        "rimraf": "^5.0.5",
        "tailwindcss": "^3.3.3",
        "typescript": "^5.3.0",
        "vitest": "^1.0.0"
    },
    "dependencies": {
        "rustywind": "^0.7.1"
    }
}
